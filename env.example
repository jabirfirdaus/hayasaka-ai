# ──────────────────────────────────────────────────────────────────
#  FILE: .env
#  Salin file ini menjadi ".env" dan isi dengan nilai yang sesuai.
#  JANGAN commit file .env ke Git!
# ──────────────────────────────────────────────────────────────────

# Token bot Telegram (dapatkan dari @BotFather di Telegram)
TELEGRAM_TOKEN=isi_token_telegram_kamu_disini

# API Key Groq (dapatkan gratis di https://console.groq.com)
GROQ_API_KEY=isi_api_key_groq_kamu_disini

# Zona waktu (sesuaikan jika bukan WIB)
# Pilihan: Asia/Jakarta (WIB), Asia/Makassar (WITA), Asia/Jayapura (WIT)
TIMEZONE=Asia/Jakarta

# Jumlah pasang pesan yang diingat per user (1 pasang = 1 pesan user + 1 respons bot)
# Semakin besar = memori lebih panjang, tapi token LLM lebih boros
MAX_MEMORY=20
